# ============================================================
#  LIFEFLOW · Variables de entorno
#  Copia este archivo como .env.local y rellena los valores.
#
#  NUNCA commitees .env.local — está en .gitignore
# ============================================================

# ─── Supabase (requerido) ─────────────────────────────────
EXPO_PUBLIC_SUPABASE_URL=https://[PROJECT_REF].supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Solo en Edge Functions / scripts server-side — NUNCA en el cliente
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ─── Mentor IA — al menos una clave requerida para IA real ─
# Sin ninguna, el mentor usa respuestas pre-programadas (modo demo).

# Opción 1: Groq (recomendado, gratis) — console.groq.com
EXPO_PUBLIC_GROQ_API_KEY=gsk_...

# Opción 2: NVIDIA NIM — build.nvidia.com
EXPO_PUBLIC_NVIDIA_API_KEY=nvapi-...

# Opción 3: OpenAI — platform.openai.com
EXPO_PUBLIC_OPENAI_API_KEY=sk-...

# ─── Embeddings (para memoria vectorial del mentor) ────────
# Se usa en la Edge Function generate-embeddings (server-side)
OPENAI_API_KEY=sk-...

# ─── Anthropic (opcional — Claude directo) ────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── App ──────────────────────────────────────────────────
EXPO_PUBLIC_APP_URL=https://growthplayers.vercel.app

# ─── RevenueCat (subscripciones) ──────────────────────────
EXPO_PUBLIC_REVENUECAT_KEY=appl_...   # iOS
# EXPO_PUBLIC_REVENUECAT_KEY_ANDROID=goog_...

# ─── Expo Push Notifications ──────────────────────────────
# Configurado automáticamente por Expo — no requiere variable manual.
# Verifica: npx expo credentials:manager

# ─── Supabase CLI (deploy edge functions) ─────────────────
# Genera en: supabase.com/dashboard/account/tokens
SUPABASE_ACCESS_TOKEN=sbp_...


# ============================================================
#  LIFEFLOW · Variables de entorno
#  Copia este archivo como .env.local y rellena los valores
#  reales.
#
#  NUNCA commitees .env.local — ya está en .gitignore
# ============================================================

# Supabase (requerido)
EXPO_PUBLIC_SUPABASE_URL=https://TU_PROJECT_ID.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── Mentor IA — al menos una clave requerida para IA real ───────────────────
# Sin ninguna de estas claves el mentor usa respuestas pre-programadas (modo demo).

# Opción 1: Groq (gratis) — obtén tu clave en console.groq.com
EXPO_PUBLIC_GROQ_API_KEY=gsk_...

# Opción 2: NVIDIA NIM — obtén tu clave en build.nvidia.com
EXPO_PUBLIC_NVIDIA_API_KEY=nvapi-...

# Opción 3: OpenAI — obtén tu clave en platform.openai.com
EXPO_PUBLIC_OPENAI_API_KEY=sk-...

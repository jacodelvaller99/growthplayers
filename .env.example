# Supabase Configuration
# Get these from https://supabase.com/dashboard
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# OpenAI Configuration
# Get API key from https://platform.openai.com/api-keys
EXPO_PUBLIC_OPENAI_API_KEY=sk-your-api-key-here

# RevenueCat Configuration (optional for testing)
# Get API key from https://revenuecat.com/dashboard
REVENUE_CAT_API_KEY=your-revenue-cat-api-key

# Whoop Integration (optional for biometrics)
# Get credentials from https://www.whoop.com/api
WHOOP_CLIENT_ID=your-whoop-client-id
WHOOP_CLIENT_SECRET=your-whoop-client-secret

# Oura Integration (optional for biometrics)
# Get credentials from https://cloud.ouraring.com
OURA_CLIENT_ID=your-oura-client-id
OURA_CLIENT_SECRET=your-oura-client-secret

# ============================================================
# LIFEFLOW — CREDENCIALES REQUERIDAS
# ============================================================
# EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
# EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-from-supabase-dashboard
# EXPO_PUBLIC_OPENAI_KEY=sk-...your-openai-api-key
# ============================================================
# SIN ESTAS CREDENCIALES: Login/Register mostrarán error de conexión
# Para configurar: https://supabase.com/dashboard → Settings → API
# ============================================================

# ============================================================
# DEV MODE — desactivar antes de producción
# Cuando está activo: permite login sin credenciales reales
# ============================================================
EXPO_PUBLIC_DEV_MODE=true

# Supabase Configuration
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# OpenAI Configuration
EXPO_PUBLIC_OPENAI_KEY=sk-test-key
EXPO_PUBLIC_OPENAI_API_KEY=sk-test-key

# RevenueCat Configuration
REVENUE_CAT_API_KEY=test-key

# Whoop Integration
WHOOP_CLIENT_ID=test-client-id
WHOOP_CLIENT_SECRET=test-client-secret

# Oura Integration
OURA_CLIENT_ID=test-client-id
OURA_CLIENT_SECRET=test-client-secret

{
  "expo": {
    "name": "Lifeflow",
    "slug": "lifeflow",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "scheme": "lifeflow",
    "newArchEnabled": true,
    "splash": {
      "backgroundColor": "#0A0A0A"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.growthplayers.lifeflow",
      "infoPlist": {
        "UIUserInterfaceStyle": "Dark"
      }
    },
    "android": {
      "package": "com.growthplayers.lifeflow",
      "adaptiveIcon": {
        "backgroundColor": "#0A0A0A"
      },
      "edgeToEdgeEnabled": true
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro",
      "output": "single"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-font"
    ]
  }
}

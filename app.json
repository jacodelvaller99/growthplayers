{
  "expo": {
    "name": "Polaris Growth Institute",
    "slug": "polaris-growth-institute",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "polaris",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "runtimeVersion": { "policy": "appVersion" },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.polarisgrowthinstitute.lifeflow",
      "buildNumber": "1",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Polaris usa el micrófono solo cuando grabas una sesión de mentoría, para transcribirla y generar tus notas. La grabación es opcional y requiere tu consentimiento."
      }
    },
    "android": {
      "package": "com.polarisgrowthinstitute.lifeflow",
      "versionCode": 1,
      "permissions": ["android.permission.RECORD_AUDIO"],
      "adaptiveIcon": {
        "backgroundColor": "#0F0F0F",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "statusBar": {
        "backgroundColor": "#0F0F0F",
        "barStyle": "light-content",
        "translucent": true
      },
      "navigationBar": {
        "backgroundColor": "#0F0F0F",
        "barStyle": "light-content"
      }
    },
    "web": {
      "output": "spa",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#0F0F0F",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-secure-store",
      "expo-font",
      [
        "expo-notifications",
        {
          "color": "#FFC804"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "privacyPolicyUrl": "https://polarisgrowthinstitute.com/privacidad",
      "eas": {
        "projectId": "00000000-0000-0000-0000-000000000000"
      }
    }
  }
}

{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Lifeflow Web",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["expo", "start", "--web", "--port", "9191"],
      "cwd": ".",
      "port": 9191,
      "autoPort": true
    },
    {
      "name": "Lifeflow Metro",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["expo", "start", "--clear", "--port", "9191"],
      "cwd": ".",
      "port": 9191,
      "autoPort": true
    },
    {
      "name": "Lifeflow Android",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["expo", "start", "--android", "--port", "9191"],
      "cwd": ".",
      "port": 9191,
      "autoPort": true
    },
    {
      "name": "Lifeflow iOS",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["expo", "start", "--ios", "--port", "9191"],
      "cwd": ".",
      "port": 9191,
      "autoPort": true
    }
  ]
}
